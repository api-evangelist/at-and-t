{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/at-and-t/refs/heads/main/json-structure/mvnx-api-topup-balance-structure.json",
  "description": "TopupBalance schema from AT&T API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique top-up transaction identifier",
      "example": "topup-500123"
    },
    "href": {
      "type": "uri",
      "example": "https://devex-web.att.com/topupBalance/topup-500123"
    },
    "status": {
      "type": "string",
      "description": "Transaction status",
      "enum": [
        "completed",
        "failed",
        "inProgress"
      ],
      "example": "completed"
    }
  },
  "name": "TopupBalance"
}