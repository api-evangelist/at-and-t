{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/at-and-t/refs/heads/main/json-structure/mvnx-api-geographic-site-structure.json",
  "description": "GeographicSite schema from AT&T API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique geographic site identifier",
      "example": "site-500123"
    },
    "name": {
      "type": "string",
      "description": "Name of the geographic site or market area",
      "example": "US Market - East"
    },
    "href": {
      "type": "uri",
      "description": "URL to this geographic site resource",
      "example": "https://devex-web.att.com/geographicSite/site-500123"
    },
    "status": {
      "type": "string",
      "description": "Site availability status",
      "example": "active"
    }
  },
  "name": "GeographicSite"
}